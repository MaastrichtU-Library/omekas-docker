############################################################################
### Use this file to declare default values for docker-compose variables ###
### See https://docs.docker.com/compose/env-file/                        ###
############################################################################

# Webserver
ENV_PHP_VERSION=8.2

# Database
ENV_MYSQL_ROOT_PASSWORD=very_difficult_password_1
ENV_MYSQL_DATABASE=omekas
ENV_MYSQL_USER=omekas
ENV_MYSQL_PASSWORD=difficult_omek4s_password
ENV_MYSQL_HOST=db

# Omeka S
ENV_OMEKAS_VERSION=4.1.1
# Note: avoid AdvancedSearch 3.4.54 and SearchSolr 3.5.61 because of bug described at https://github.com/Daniel-KM/Omeka-S-module-SearchSolr/issues/18
ENV_MODULE_AdvancedSearch_VERSION=3.4.53
ENV_MODULE_SearchSolr_VERSION=3.5.60
ENV_MODULE_ArchiveRepertory_VERSION=3.15.17
ENV_MODULE_Ark_VERSION=3.5.15
ENV_MODULE_BlockPlus_VERSION=3.4.42
ENV_MODULE_BlocksDisposition_VERSION=3.4.5
ENV_MODULE_BulkEdit_VERSION=3.4.37
ENV_MODULE_BulkExport_VERSION=3.4.37
ENV_MODULE_Common_VERSION=3.4.74
ENV_MODULE_CreateMissingThumbnails_VERSION=0.3.0
ENV_MODULE_CSVImport_VERSION=2.6.2
ENV_MODULE_CustomVocab_VERSION=2.0.2
ENV_MODULE_EasyAdmin_VERSION=3.4.37
ENV_MODULE_EUCookieBar_VERSION=3.4.5
ENV_MODULE_ExtractText_VERSION=2.1.0
ENV_MODULE_FileSideload_VERSION=1.7.1
ENV_MODULE_HideProperties_VERSION=1.3.1
# Notes on IiifServer and IiifSearch: Make sure that you deselect `Cache > Cache manifest for instant access` in the IiifServer module settings in case search is not working.
# Another indication is that the IIIF manifest lacks a section for "service" with "@context": "http://iiif.io/api/search/0/context.json"
ENV_MODULE_IiifSearch_VERSION=3.4.8
ENV_MODULE_IiifServer_VERSION=3.6.26
ENV_MODULE_ImageServer_VERSION=3.6.20
ENV_MODULE_LinkedDataSets_VERSION=0.3.1-mc
ENV_MODULE_Log_VERSION=3.4.33
# Notes on Mirador versions and plugins.
# - 3.4.9  Plugins Annotations and OCRhelper not working
# - 3.4.10 Plugin OCRhelper works, Annotations not working and generates console error in browser "TypeError: Cannot read properties of undefined (reading 'alternate')"
# - 3.4.11 Introduces Mirador v4, plugins Annotations and OCR Helper are not compatible with Mirador v4 (as written in README.md). Furthermore, it is not possible to select v3 and v4 plugins in the site settings (bug?). Avoid this version!
ENV_MODULE_Mirador_VERSION=3.4.10
ENV_MODULE_ModelViewer_VERSION=3.3.0.7-132-fork-mc2
ENV_MODULE_NdeTermennetwerk_VERSION=1.4.0
ENV_MODULE_NumericDataTypes_VERSION=1.13.0
ENV_MODULE_PdfViewer_VERSION=3.4.4
ENV_MODULE_ResourceMeta_VERSION=1.1.0
ENV_MODULE_Sitemaps_VERSION=1.1
ENV_MODULE_UniversalViewer_VERSION=3.6.11-4.2.1
ENV_MODULE_ValueSuggest_VERSION=1.19.0
ENV_THEME_Default_VERSION=1.9.1

# External IIIF tooling
ENV_IIPSRV_VERSION=version-3.11.0
ENV_CANTALOUPE_VERSION=5.0.6-3
ENV_MIRADOR_VERSION=4.0.0.alpha-2

# Triplestore tooling
ENV_GRAPHDB_VERSION=11.4.0
